<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.zero.anchor">

    <!--
    ============================================
    必需权限声明 - 意图干预 App 权限说明
    ============================================
    
    1. SYSTEM_ALERT_WINDOW: 悬浮窗权限
       - 用途: 允许应用在其他应用之上绘制 Overlay
       - 注意: 需要用户在系统设置中手动授权
    
    2. BIND_ACCESSIBILITY_SERVICE: 无障碍服务权限
       - 用途: 监听窗口变化，检测目标应用启动
       - 注意: 这是系统级权限，需要用户在无障碍设置中启用
       
    3. FOREGROUND_SERVICE: 前台服务权限 (Android 9+)
       - 用途: 保持服务在后台运行，防止被系统杀死
    
    4. RECEIVE_BOOT_COMPLETED: 开机自启动权限
       - 用途: 设备重启后自动启动服务
    
    5. QUERY_ALL_PACKAGES: 查询所有应用权限
       - 用途: 获取设备上安装的应用列表，让用户选择要监控的应用
    -->

    <!-- 悬浮窗权限 - 用于显示干预 Overlay -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    
    <!-- 无障碍服务权限 - 核心权限，用于检测应用启动 -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />
    
    <!-- 前台服务权限 - Android 9.0+ 需要 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    
    <!-- 开机自启动权限 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- 唤醒权限 - 可选，用于在屏幕关闭时也能干预 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- 通知权限 - Android 13+ 必须声明，否则通知权限开关为灰色 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- 查询所有应用权限 - 获取设备上的应用列表 -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ZeroAnchor"
        tools:targetApi="34">

        <!-- 主 Activity - 应用入口 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 应用选择 Activity - 用于选择要监控的应用 -->
        <activity
            android:name=".AppListActivity"
            android:exported="false"
            android:theme="@style/Theme.ZeroAnchor" />

        <!-- 
        ============================================
        AccessibilityService 声明 - 核心服务
        ============================================
        
        这是检测目标应用启动的核心组件。
        用户必须在 设置 > 无障碍 > 正念干预 中手动启用。
        -->
        <service
            android:name=".MindfulAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:foregroundServiceType="dataSync">
            
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            
            <!-- 无障碍服务配置 -->
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!--
        ============================================
        KeepAlive Service 声明 - 独立保活服务
        ============================================

        独立的保活服务，与无障碍服务完全分离。
        显示持久通知，确保应用在后台也能运行。
        -->
        <service
            android:name=".KeepAliveNotificationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- 开机自启动接收器 -->
        <receiver
            android:name=".BootCompletedReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
