<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0-Anchor"
            android:textSize="28sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="既然大脑的刹车失灵，就交给代码执行。"
            android:textSize="14sp"
            android:textColor="#666666"
            android:paddingBottom="24dp" />

        <LinearLayout
            android:id="@+id/status_card_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="一、无障碍服务"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tv_accessibility_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✗ 未启用"
                android:textSize="14sp"
                android:textColor="#E53935"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_enable_accessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="去开启无障碍服务"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_red" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_card_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="二、悬浮窗权限"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tv_overlay_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✗ 未授权"
                android:textSize="14sp"
                android:textColor="#E53935"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_enable_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="去开启悬浮窗权限"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_red" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_card_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="三、通知权限"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tv_notification_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✗ 未授权（常驻通知保活）"
                android:textSize="14sp"
                android:textColor="#E53935"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_enable_notification"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="去开启通知权限"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_red" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_card_query_packages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="四、读取应用列表"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tv_query_packages_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✗ 未授权"
                android:textSize="14sp"
                android:textColor="#E53935"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_enable_query_packages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="去开启读取应用列表权限"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_red" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_card_battery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="五、电池优化"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tv_battery_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✗ 未优化（会被后台清理）"
                android:textSize="14sp"
                android:textColor="#E53935"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_enable_battery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="去关闭电池优化"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_red" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_card_auto_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="六、自启动"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tv_auto_start_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✗ 未允许（重启后需手动开启）"
                android:textSize="14sp"
                android:textColor="#E53935"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_enable_auto_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="去允许自启动"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_red" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_card_overall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="七、整体状态"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tv_overall_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请先完成以上权限设置"
                android:textSize="14sp"
                android:textColor="#FF9800" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_card_apps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="八、监控应用管理"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择要监控的应用"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_manage_apps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择监控应用"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_blue" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_card_cooldown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="九、冷却设置"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="设置娱乐模式冷却时间"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_cooldown_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60 分钟"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/btn_decrease_cooldown"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="-"
                    android:textSize="32sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_blue"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="12dp" />

                <Button
                    android:id="@+id/btn_increase_cooldown"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="+"
                    android:textSize="32sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_blue"
                    android:gravity="center"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_card_auto_center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="十、气泡居中设置"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="任务气泡自动回到屏幕居中间的间隔"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_auto_center_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60 秒"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/btn_decrease_auto_center"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="-"
                    android:textSize="32sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_blue"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="12dp" />

                <Button
                    android:id="@+id/btn_increase_auto_center"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="+"
                    android:textSize="32sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_blue"
                    android:gravity="center"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="十一、测试"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="模拟弹出拦截界面，测试功能是否正常"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_test"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="模拟弹出"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_green"
                android:enabled="false" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="使用说明\n\n1. 依次完成以上权限的设置\n2. 在「监控应用管理」中选择要拦截的应用\n3. 当您打开选定的应用时，会弹出干预界面\n4. 您可以选择「任务模式」或「娱乐模式」\n\n任务模式：记录任务名称，正向计时\n娱乐模式：设定使用时长，倒计时结束自动返回桌面\n娱乐模式冷却时间：娱乐模式结束后N分钟内不能再次进入娱乐模式\n\n⚠️ 建议同时开启电池优化和自启动，确保应用稳定运行\n\n本工具使用Gemini和TRAE SOLO制作，不用于商业用途。\n使用问题请联系小红书ID:947474213。"
            android:textSize="12sp"
            android:textColor="#888888"
            android:paddingTop="16dp"
            android:lineSpacingMultiplier="1.3" />

    </LinearLayout>
</ScrollView>
